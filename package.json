{
  "name": "@amautas-core/amautas-platform-admin",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start:local": "ng serve  --port 4201",
    "start:dev": "ng serve  --port 4201 --configuration=dev",
    "start:staging": "ng serve  --port 4201 --configuration=staging",
    "start:prod": "ng serve  --port 4201 --configuration=production",
    "link:ui": "npm link ui-kit",
    "update:ui-kit": "npm run update:ui-kit --prefix ../..",
    "dev:all": "npm run dev:all --prefix ../..",
    "relink:ui": "npm unlink ui-kit || true && npm link ui-kit",
    "unlink:ui": "npm unlink ui-kit || true && npm install",
    "doctor:ui": "npm ls ui-kit",
    "reset": "rimraf node_modules .angular package-lock.json",
    "reinstall": "npm run reset && npm install",
    "clean": "node -e \"const fs=require('fs');fs.rmSync('dist',{recursive:true,force:true});fs.rmSync('.angular',{recursive:true,force:true})\"",
    "lint": "eslint .",
    "build": "ng build",
    "build:dev": "ng build --configuration=dev",
    "build:staging": "ng build --configuration=staging",
    "build:prod": "ng build --configuration=production",
    "watch": "ng build --watch --configuration development",
    "test": "ng test --watch=false --browsers=ChromeHeadlessNoSandbox",
    "test:watch": "ng test"
  },
  "prettier": {
    "overrides": [
      {
        "files": "*.html",
        "options": {
          "parser": "angular"
        }
      }
    ]
  },
  "private": true,
  "dependencies": {
    "@angular/cdk": "^20.2.0",
    "@angular/common": "^20.1.0",
    "@angular/compiler": "^20.1.0",
    "@angular/core": "^20.1.0",
    "@angular/forms": "^20.1.0",
    "@angular/material": "^20.2.0",
    "@angular/platform-browser": "^20.1.0",
    "@angular/router": "^20.1.0",
    "@ngx-translate/core": "^15.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "chart.js": "^4.4.0",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "ng2-charts": "^4.1.1",
    "ngx-dropzone": "^3.1.0",
    "ngx-quill": "^28.0.2",
    "quill": "^2.0.3",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "ui-kit": "0.0.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^20.2.0",
    "@angular/build": "^20.1.4",
    "@angular/cli": "^20.1.4",
    "@angular/compiler-cli": "^20.1.0",
    "@types/crypto-js": "^4.2.2",
    "@types/jasmine": "~5.1.0",
    "cross-env": "^10.0.0",
    "jasmine-core": "~5.8.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.8.2"
  }
}
