  readonly summarySaving = signal(false);

  readonly tenantBrandingForm = this.fb.nonNullable.group({
    primaryColor: ['#0fa2cc', Validators.pattern(HEX_PATTERN)],
    secondaryColor: ['#f4ece4', Validators.pattern(HEX_PATTERN)],
    sidebarBgColor: ['#0fa2cc', Validators.pattern(HEX_PATTERN)],
    headerBgColor: ['#f4ece4', Validators.pattern(HEX_PATTERN)],
    pageBackgroundColor: ['#fbf1e8', Validators.pattern(HEX_PATTERN)],
    buttonPrimaryColor: ['#0fa2cc', Validators.pattern(HEX_PATTERN)],
    buttonSecondaryColor: ['#f4ece4', Validators.pattern(HEX_PATTERN)],
    buttonCancelColor: ['#5f6b7a', Validators.pattern(HEX_PATTERN)],
    textColor: ['#0f2630', Validators.pattern(HEX_PATTERN)],
    fontFamily: [''],
    headingFontFamily: [''],
    baseFontSize: [16 as number | string],
    loginBackgroundUrl: [''],
    logoUrl: [''],
    logoDarkUrl: [''],
    logoReducedUrl: [''],
    logoDarkReducedUrl: [''],
    faviconUrl: [''],
    logoSlotSidebar: ['primary' as TenantLogoVariant],
    logoSlotLogin: ['primary' as TenantLogoVariant],
    logoSlotFavicon: ['primary' as TenantLogoVariant],
    logoSlotSidebarCollapsed: ['primary' as TenantLogoVariant],
