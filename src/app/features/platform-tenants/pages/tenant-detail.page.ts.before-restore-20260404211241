  readonly paletteRecommendations = signal<ThemePalette[]>([]);
  readonly fontPresets = FONT_PRESETS;
  readonly selectedFontPresetId = signal<string>('custom');

  /** Consola tenant: menú lateral plano para no admin (tenant_setting). */
